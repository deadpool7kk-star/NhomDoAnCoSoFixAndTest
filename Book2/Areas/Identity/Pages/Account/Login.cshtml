@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Auth.css" asp-append-version="true" />
}

<div class="auth-wrapper">
    <div class="auth-container">
        <div class="auth-header">
            <h1 class="brand-title">FrancisBooks</h1>
            <p class="auth-subtitle">Chào mừng bạn quay lại</p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert" style="font-size: 0.9rem;"></div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email">Email của bạn</label>
                <span asp-validation-for="Input.Email" class="text-danger ms-2" style="font-size:0.85rem"></span>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.Password">Mật khẩu</label>
                <span asp-validation-for="Input.Password" class="text-danger ms-2" style="font-size:0.85rem"></span>
            </div>
            
            <div class="d-flex justify-content-between align-items-center mb-4 px-1">
                <div class="form-check">
                    <input class="form-check-input" asp-for="Input.RememberMe" id="rememberMe" />
                    <label class="form-check-label text-muted" for="rememberMe" style="font-size: 0.9rem;">
                        Nhớ đăng nhập
                    </label>
                </div>
                <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none" style="font-weight: 500; font-size: 0.9rem; color: var(--green-600);">Quên mật khẩu?</a>
            </div>
            
            <button id="login-submit" type="submit" class="btn-auth-primary mb-4">
                Đăng nhập
            </button>
            
            <div class="text-center text-muted mb-2" style="font-size: 0.95rem;">
                Chưa có tài khoản? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-bold" style="color: var(--green-600);">Đăng ký ngay</a>
            </div>
        </form>

        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="auth-divider">hoặc đăng nhập bằng</div>
            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                @foreach (var provider in Model.ExternalLogins!)
                {
                    if (provider.DisplayName == "Google")
                    {
                        <button type="submit" class="btn-google mt-2" name="provider" value="@provider.Name" title="Đăng nhập bằng @provider.DisplayName">
                            <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48"><g><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"></path><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"></path><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"></path><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"></path><path fill="none" d="M0 0h48v48H0z"></path></g></svg>
                            Tiếp tục với Google
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-outline-secondary w-100 mt-2" name="provider" value="@provider.Name">
                            Đăng nhập bằng @provider.DisplayName
                        </button>
                    }
                }
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
