@using Book2.Models
@inject SignInManager<ApplicationUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}
<ul class="nav nav-pills flex-column gap-2">
    <li class="nav-item">
        <a class="nav-link px-3 py-2 fw-medium rounded-pill @ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="./Index">
            <i class="bi bi-person-badge me-2"></i> Hồ sơ cá nhân
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link px-3 py-2 fw-medium rounded-pill @ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="./ChangePassword">
            <i class="bi bi-shield-lock me-2"></i> Đổi mật khẩu
        </a>
    </li>
    @if (hasExternalLogins)
    {
        <li id="external-logins" class="nav-item">
            <a id="external-login" class="nav-link px-3 py-2 fw-medium rounded-pill @ManageNavPages.ExternalLoginsNavClass(ViewContext)" asp-page="./ExternalLogins">
                <i class="bi bi-link-45deg me-2"></i> Liên kết tài khoản
            </a>
        </li>
    }
    <li><hr class="dropdown-divider my-2"></li>
    <li class="nav-item">
        <form class="m-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
            <button type="submit" class="nav-link px-3 py-2 fw-medium rounded-pill w-100 text-start text-danger" style="background: none; border: none;">
                <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
            </button>
        </form>
    </li>
</ul>

<style>
    .nav-pills .nav-link {
        color: #495057;
        transition: all 0.2s ease-in-out;
    }
    .nav-pills .nav-link:hover:not(.active) {
        background-color: rgba(0,0,0,0.05);
    }
    .nav-pills .nav-link.active {
        background-color: var(--green-500) !important;
        color: white !important;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }
</style>
