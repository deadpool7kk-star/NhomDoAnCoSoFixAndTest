@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3 class="fw-bold mb-4">@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-9">
        <form id="change-password-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.OldPassword" class="form-control rounded-3" autocomplete="current-password" aria-required="true" placeholder="Mật khẩu cũ" />
                <label asp-for="Input.OldPassword" class="form-label">Mật khẩu hiện tại</label>
                <span asp-validation-for="Input.OldPassword" class="text-danger ms-2 small"></span>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.NewPassword" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="Mật khẩu mới" />
                <label asp-for="Input.NewPassword" class="form-label">Mật khẩu mới</label>
                <span asp-validation-for="Input.NewPassword" class="text-danger ms-2 small"></span>
            </div>
            
            <div class="form-floating mb-4">
                <input asp-for="Input.ConfirmPassword" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="Xác nhận mật khẩu mới"/>
                <label asp-for="Input.ConfirmPassword" class="form-label">Xác nhận mật khẩu mới</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger ms-2 small"></span>
            </div>
            
            <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm">
                <i class="bi bi-shield-lock me-1"></i> Cập nhật mật khẩu
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
