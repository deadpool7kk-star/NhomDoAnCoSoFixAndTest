@model IEnumerable<Book2.Models.PhieuNhap>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Nhập kho";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Lịch sử Nhập kho</h2>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> Tạo phiếu nhập mới
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 shadow-sm mb-4">@TempData["Success"]</div>
}

<div class="card border-0 shadow-sm" style="border-radius: 12px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Ngày nhập</th>
                        <th>Nhà cung cấp</th>
                        <th>Tổng tiền</th>
                        <th>Ghi chú</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">#@item.Id</td>
                            <td>@item.NgayNhap.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="fw-bold">@item.NhaXuatBan?.TenNhaXuatBan</td>
                            <td class="text-success fw-bold">@item.TongTien.ToString("N0")₫</td>
                            <td class="text-muted small">@item.GhiChu</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-pill px-3">
                                    <i class="bi bi-eye"></i> Chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
