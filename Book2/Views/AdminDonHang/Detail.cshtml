@model IEnumerable<Book2.Models.ChiTietDonHang>

@{
    if (User.IsInRole("Admin"))
    {
        Layout = "_AdminLayout";
    }
    else if (User.IsInRole("Staff"))
    {
        Layout = "_AdminLayout";
    }
    else
    {
        Layout = "_ShipperLayout";
    }

    ViewData["Title"] = "Chi tiết đơn hàng";
    var donHang = ViewBag.DonHang as Book2.Models.DonHang;
    var trangThaiList = ViewBag.TrangThaiList as List<string> ?? new();
}

@if (donHang != null)
{
    <div class="card card-box mb-4">
        <div class="card-body">
            <h3 class="fw-bold mb-3">Đơn hàng #@donHang.Id</h3>

            <div class="row">
                <div class="col-md-6">
                    <p><strong>Người nhận:</strong> @donHang.TenNguoiNhan</p>
                    <p><strong>SĐT:</strong> @donHang.SoDienThoai</p>
                    <p><strong>Địa chỉ:</strong> @donHang.DiaChiNhanHang</p>
                </div>

                <div class="col-md-6 text-end">
                    <p><strong>Ngày đặt:</strong> @donHang.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Tạm tính:</strong> @((donHang.TongTien + donHang.SoTienGiam).ToString("N0"))₫</p>
                    @if (donHang.SoTienGiam > 0)
                    {
                        <p class="text-danger"><strong>Giảm giá (@donHang.CouponCode):</strong> -@donHang.SoTienGiam.ToString("N0")₫</p>
                    }
                    <p class="text-success h5"><strong>Tổng thanh toán:</strong> @donHang.TongTien.ToString("N0")₫</p>
                    <p>
                        <strong>Trạng thái hiện tại:</strong>
                        @if (donHang.TrangThai == "Chờ xác nhận")
                        {
                            <span class="badge bg-secondary">@donHang.TrangThai</span>
                        }
                        else if (donHang.TrangThai == "Đang giao")
                        {
                            <span class="badge bg-primary">@donHang.TrangThai</span>
                        }
                        else if (donHang.TrangThai == "Hoàn thành")
                        {
                            <span class="badge bg-success">@donHang.TrangThai</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">@donHang.TrangThai</span>
                        }
                    </p>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-3 border-top pt-3">
                @if (donHang.TrangThai != "Hoàn thành" && donHang.TrangThai != "Đã hủy")
                {
                    <form asp-action="UpdateStatus" method="post" class="flex-grow-1 me-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@donHang.Id" />

                        <div class="row g-3 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label small">Cập nhật trạng thái</label>
                                <select name="trangThai" class="form-select">
                                    @foreach (var item in trangThaiList)
                                    {
                                        if (item == donHang.TrangThai)
                                        {
                                            <option value="@item" selected>@item</option>
                                        }
                                        else
                                        {
                                            <option value="@item">@item</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="col-md-3">
                                <button type="submit" class="btn btn-success px-4">Lưu trạng thái</button>
                            </div>
                        </div>
                    </form>
                }
                
                @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                {
                    <a asp-action="InHoaDon" asp-route-id="@donHang.Id" class="btn btn-outline-dark px-4" target="_blank">
                        <i class="bi bi-printer me-1"></i> In Hóa Đơn PDF
                    </a>
                }
            </div>
        </div>
    </div>
}

<div class="card card-box">
    <div class="card-body">
        <h4 class="fw-bold mb-3">Sản phẩm trong đơn</h4>

        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Tên sách</th>
                    <th>Đơn giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(item.Sach?.TenSach ?? "Không còn dữ liệu")</td>
                        <td>@item.DonGia.ToString("N0") VNĐ</td>
                        <td>@item.SoLuong</td>
                        <td>@((item.DonGia * item.SoLuong).ToString("N0")) VNĐ</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>