@model IEnumerable<Book2.Models.DonHang>

@{
    if (User.IsInRole("Admin"))
    {
        Layout = "_AdminLayout";
    }
    else if (User.IsInRole("Staff"))
    {
        Layout = "_AdminLayout";
    }
    else
    {
        Layout = "_ShipperLayout";
    }

    ViewData["Title"] = "Quản lý đơn hàng";
}

<h2 class="fw-bold mb-4">Quản lý đơn hàng</h2>

<div class="card card-box">
    <div class="card-body">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Mã đơn</th>
                    <th>Người nhận</th>
                    <th>SĐT</th>
                    <th>Ngày đặt</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Chi tiết</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.Id</td>
                        <td>@item.TenNguoiNhan</td>
                        <td>@item.SoDienThoai</td>
                        <td>@item.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.TongTien.ToString("N0") VNĐ</td>
                        <td>
                            @if (item.TrangThai == "Chờ xác nhận")
                            {
                                <span class="badge bg-secondary">@item.TrangThai</span>
                            }
                            else if (item.TrangThai == "Đang giao")
                            {
                                <span class="badge bg-primary">@item.TrangThai</span>
                            }
                            else if (item.TrangThai == "Hoàn thành")
                            {
                                <span class="badge bg-success">@item.TrangThai</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">@item.TrangThai</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                Xem
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>