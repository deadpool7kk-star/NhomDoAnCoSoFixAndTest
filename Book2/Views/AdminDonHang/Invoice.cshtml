@model IEnumerable<Book2.Models.ChiTietDonHang>

@{
    Layout = null;
    var donHang = ViewBag.DonHang as Book2.Models.DonHang;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Hóa đơn #@donHang?.Id</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding: 20px; color: #333; }
        .header { text-align: center; border-bottom: 2px solid #198754; padding-bottom: 20px; margin-bottom: 30px; }
        .header h1 { color: #198754; margin: 0; }
        .info { margin-bottom: 30px; }
        .info-table { width: 100%; border-collapse: collapse; }
        .info-table td { padding: 5px 0; }
        .items-table { width: 100%; border-collapse: collapse; margin-bottom: 30px; }
        .items-table th { background-color: #f8f9fa; border-bottom: 2px solid #dee2e6; padding: 12px; text-align: left; }
        .items-table td { border-bottom: 1px solid #dee2e6; padding: 12px; }
        .total-section { text-align: right; }
        .total-section p { font-size: 1.2rem; font-weight: bold; }
        .footer { text-align: center; margin-top: 50px; font-size: 0.9rem; color: #6c757d; }
    </style>
</head>
<body>
    <div class="header">
        <h1>NHÀ SÁCH BOOK2</h1>
        <p>HÓA ĐƠN BÁN LẺ</p>
    </div>

    <div class="info">
        <table class="info-table">
            <tr>
                <td width="150"><strong>Mã đơn hàng:</strong></td>
                <td>#@donHang?.Id</td>
                <td width="150"><strong>Ngày đặt:</strong></td>
                <td>@donHang?.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
            <tr>
                <td><strong>Người nhận:</strong></td>
                <td>@donHang?.TenNguoiNhan</td>
                <td><strong>Số điện thoại:</strong></td>
                <td>@donHang?.SoDienThoai</td>
            </tr>
            <tr>
                <td><strong>Địa chỉ:</strong></td>
                <td colspan="3">@donHang?.DiaChiNhanHang</td>
            </tr>
        </table>
    </div>

    <table class="items-table">
        <thead>
            <tr>
                <th>Sách</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th>Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Sach?.TenSach</td>
                    <td>@item.SoLuong</td>
                    <td>@item.DonGia.ToString("N0")₫</td>
                    <td>@((item.SoLuong * item.DonGia).ToString("N0"))₫</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="total-section">
        @if (donHang != null && donHang.SoTienGiam > 0)
        {
            <p style="color: #dc3545;">Giảm giá (@donHang.CouponCode): -@donHang.SoTienGiam.ToString("N0")₫</p>
        }
        <p>TỔNG THANH TOÁN: <span style="color: #198754;">@donHang?.TongTien.ToString("N0")₫</span></p>
    </div>

    <div class="footer">
        <p>Cảm ơn quý khách đã mua hàng tại Book2!</p>
        <p>Mọi thắc mắc vui lòng liên hệ: 0123.456.789</p>
    </div>
</body>
</html>
