@model Book2.Models.PhieuNhap

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết phiếu nhập";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Chi tiết Phiếu nhập #@Model.Id</h2>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
        <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
    </a>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 12px;">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 border-bottom pb-2 text-primary">Thông tin chung</h5>
                <p class="mb-2"><strong>Ngày nhập:</strong> @Model.NgayNhap.ToString("dd/MM/yyyy HH:mm")</p>
                <p class="mb-2"><strong>Nhà cung cấp:</strong> @Model.NhaXuatBan?.TenNhaXuatBan</p>
                <p class="mb-2"><strong>Ghi chú:</strong> @(string.IsNullOrEmpty(Model.GhiChu) ? "Không có" : Model.GhiChu)</p>
                <div class="mt-4 p-3 bg-light rounded" style="border-left: 4px solid #198754;">
                    <span class="text-muted d-block small mb-1">Tổng tiền thanh toán:</span>
                    <span class="h4 fw-bold text-success mb-0">@Model.TongTien.ToString("N0")₫</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 12px;">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 border-bottom pb-2 text-primary">Danh mục sản phẩm</h5>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Tên sách</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Giá nhập</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ChiTietPhieuNhaps)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold">@item.Sach?.TenSach</div>
                                    </td>
                                    <td class="text-center">@item.SoLuong</td>
                                    <td class="text-end">@item.GiaNhap.ToString("N0")₫</td>
                                    <td class="text-end fw-bold">@item.ThanhTien.ToString("N0")₫</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
