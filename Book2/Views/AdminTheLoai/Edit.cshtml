@model Book2.Models.TheLoai

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Sửa thể loại";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Chỉnh sửa thể loại</h2>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 12px; max-width: 700px; margin: 0 auto;">
    <div class="card-body p-4 p-md-5">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-4">
                <label asp-for="TenTheLoai" class="form-label fw-semibold text-muted">Tên thể loại <span class="text-danger">*</span></label>
                <input asp-for="TenTheLoai" class="form-control bg-light border-0 px-3 py-2" style="border-radius: 8px;" />
                <span asp-validation-for="TenTheLoai" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-4">
                <label asp-for="MoTa" class="form-label fw-semibold text-muted">Mô tả</label>
                <textarea asp-for="MoTa" class="form-control bg-light border-0 px-3 py-2" rows="4" style="border-radius: 8px;"></textarea>
            </div>

            <hr class="my-4 text-muted">
            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-light rounded-pill px-4 fw-medium border">Hủy bỏ</a>
                <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
                    <i class="bi bi-save me-1"></i> Cập nhật
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}