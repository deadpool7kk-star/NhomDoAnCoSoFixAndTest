@model Book2.ViewModels.CartVM

@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Giỏ hàng của bạn</h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary rounded-pill">
            <i class="bi bi-arrow-left me-1"></i> Tiếp tục mua sách
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model != null && Model.Items.Any())
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0" style="border-radius: 12px;">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Sách</th>
                                        <th>Giá</th>
                                        <th style="width: 150px;">Số lượng</th>
                                        <th>Thành tiền</th>
                                        <th class="text-center">Xóa</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Items)
                                    {
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "/images/no-image.png" : item.HinhAnh)"
                                                         style="width: 60px; height: 80px; object-fit: cover;"
                                                         class="rounded shadow-sm me-3"
                                                         alt="@item.TenSach" />
                                                    <div>
                                                        <div class="fw-bold text-dark">@item.TenSach</div>
                                                        <small class="text-muted">@item.TacGia</small>
                                                    </div>
                                                </div>
                                            </td>

                                            <td class="fw-semibold">
                                                @item.Gia.ToString("N0")₫
                                            </td>

                                            <td>
                                                <form asp-action="CapNhatSoLuong" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="chiTietGioHangId" value="@item.ChiTietGioHangId" />
                                                    <div class="input-group input-group-sm">
                                                        <input type="number"
                                                               name="soLuong"
                                                               value="@item.SoLuong"
                                                               min="0"
                                                               max="99"
                                                               class="form-control text-center" />
                                                        <button type="submit" class="btn btn-outline-secondary">
                                                            <i class="bi bi-arrow-repeat"></i>
                                                        </button>
                                                    </div>
                                                </form>
                                            </td>

                                            <td class="fw-bold text-primary">
                                                @item.ThanhTien.ToString("N0")₫
                                            </td>

                                            <td class="text-center">
                                                <form asp-action="Xoa" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa sách này khỏi giỏ hàng?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="chiTietGioHangId" value="@item.ChiTietGioHangId" />
                                                    <button type="submit" class="btn btn-link text-danger p-0">
                                                        <i class="bi bi-trash fs-5"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <form asp-action="XoaTatCa" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa toàn bộ giỏ hàng?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-link text-muted text-decoration-none p-0">
                            <i class="bi bi-x-circle me-1"></i> Xóa toàn bộ giỏ hàng
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-lg-4">
                <!-- Mã giảm giá -->
                <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">Mã giảm giá</h5>
                        <form asp-action="ApplyCoupon" method="post">
                            @Html.AntiForgeryToken()
                            <div class="input-group">
                                <input type="text" name="couponCode" class="form-control" placeholder="Nhập mã giảm giá..." value="@Model.CouponCode" />
                                <button class="btn btn-dark px-3" type="submit">Áp dụng</button>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.CouponCode))
                            {
                                <div class="mt-2 small text-success">
                                    <i class="bi bi-check-circle me-1"></i> Đang áp dụng mã: <strong>@Model.CouponCode</strong>
                                </div>
                            }
                        </form>
                    </div>
                </div>

                <!-- Tạm tính -->
                <div class="card shadow-sm border-0" style="border-radius: 12px; background-color: #f8f9fa;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Tổng cộng</h5>
                        
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tạm tính:</span>
                            <span class="fw-bold">@Model.TongTienChuaGiam.ToString("N0")₫</span>
                        </div>

                        @if (Model.DiscountPercentage.HasValue)
                        {
                            <div class="d-flex justify-content-between mb-2 text-danger">
                                <span>Giảm giá (@Model.DiscountPercentage%):</span>
                                <span>-@Model.SoTienGiam.ToString("N0")₫</span>
                            </div>
                        }

                        <hr />

                        <div class="d-flex justify-content-between mb-4">
                            <span class="h5 fw-bold mb-0">Thanh toán:</span>
                            <span class="h5 fw-bold mb-0 text-success">@Model.TongThanhToan.ToString("N0")₫</span>
                        </div>

                        <a asp-controller="DatHang" asp-action="ThanhToan" class="btn btn-success w-100 btn-lg rounded-pill shadow-sm py-3 fw-bold">
                            TIẾN HÀNH ĐẶT HÀNG
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="bi bi-cart-x text-muted" style="font-size: 5rem;"></i>
            </div>
            <h4 class="fw-bold">Giỏ hàng của bạn đang trống</h4>
            <p class="text-muted">Hãy chọn cho mình những cuốn sách thật hay nhé!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 mt-3 shadow-sm">
                Đến cửa hàng ngay
            </a>
        </div>
    }
</div>