@using Microsoft.EntityFrameworkCore
@inject Book2.Data.ApplicationDbContext _context
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var isHomePage = controller == "Home" && action == "Index";
    var theLoaisLayout = _context.TheLoais.OrderBy(x => x.TenTheLoai).ToList();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FrancisBooks</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Book.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/LandingPage.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-white">

    <header class="store-header">
        <div class="store-header-top">
            <div class="store-logo-wrap">
                <a asp-controller="Home" asp-action="Index" class="store-logo">
                    <span class="store-logo-icon">📚</span>
                    <span class="store-logo-text">Francis<span>Books</span></span>
                </a>
                <small class="store-logo-sub">Nhà sách trực tuyến</small>
            </div>

            <div class="search-dropdown-container">
                <form method="get" asp-controller="Home" asp-action="Index" class="store-search" id="searchForm">
                    <input type="text"
                           name="tuKhoa"
                           id="searchInput"
                           value="@ViewBag.TuKhoa"
                           autocomplete="off"
                           placeholder="Tìm kiếm sách, tác giả..." />

                    @if (ViewBag.TheLoaiId != null)
                    {
                        <input type="hidden" name="theLoaiId" value="@ViewBag.TheLoaiId" />
                    }

                    <button type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </form>
                <div class="search-dropdown" id="searchDropdown">
                    <!-- Results will be populated here by JS -->
                </div>
            </div>

            <div class="store-tools">
                <a href="tel:0932329959" class="store-tool-item">
                    <div class="store-tool-icon">
                        <i class="bi bi-telephone-inbound"></i>
                    </div>
                    <div class="store-tool-text">
                        <span>Gọi đặt hàng</span>
                        <strong>0932329959</strong>
                    </div>
                </a>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="dropdown">
                        <a href="#" class="store-tool-item text-decoration-none" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="color: var(--text-dark); cursor: pointer;">
                            <div class="store-tool-icon">
                                <i class="bi bi-person"></i>
                            </div>
                            <div class="store-tool-text">
                                <span>Tài khoản</span>
                                <strong>@User.Identity.Name</strong>
                            </div>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="userDropdown">
                            <li>
                                <a class="dropdown-item py-2" asp-area="Identity" asp-page="/Account/Manage/Index">
                                    <i class="bi bi-person-fill me-2"></i> @User.Identity.Name
                                </a>
                            </li>
                            <li>
                                <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                    <button type="submit" class="dropdown-item py-2 border-0 bg-transparent w-100 text-start">
                                        <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin"
                           asp-action="Dashboard"
                           class="store-tool-item">
                            <div class="store-tool-icon">
                                <i class="bi bi-speedometer2"></i>
                            </div>
                            <div class="store-tool-text">
                                <span>Quản trị</span>
                                <strong>Admin</strong>
                            </div>
                        </a>
                    }
                    else if (User.IsInRole("Staff"))
                    {
                        <a asp-controller="Staff"
                           asp-action="Dashboard"
                           class="store-tool-item">
                            <div class="store-tool-icon">
                                <i class="bi bi-briefcase"></i>
                            </div>
                            <div class="store-tool-text">
                                <span>Nhân viên</span>
                                <strong>Staff</strong>
                            </div>
                        </a>
                    }
                    else if (User.IsInRole("Shipper"))
                    {
                        <a asp-controller="Shipper"
                           asp-action="Dashboard"
                           class="store-tool-item">
                            <div class="store-tool-icon">
                                <i class="bi bi-truck"></i>
                            </div>
                            <div class="store-tool-text">
                                <span>Giao hàng</span>
                                <strong>Shipper</strong>
                            </div>
                        </a>
                    }
                    @await Component.InvokeAsync("GioHang")
                }
                else
                {
                    <a asp-area="Identity"
                       asp-page="/Account/Login"
                       class="store-tool-item">
                        <div class="store-tool-icon">
                            <i class="bi bi-person"></i>
                        </div>
                        <div class="store-tool-text">
                            <span>Tài khoản</span>
                            <strong>Đăng nhập</strong>
                        </div>
                    </a>

                    <a asp-area="Identity"
                       asp-page="/Account/Login"
                       class="store-cart-link">
                        <div class="store-cart-icon-wrap">
                            <i class="bi bi-cart3"></i>
                        </div>
                        <span>Giỏ hàng</span>
                    </a>
                }
            </div>
        </div>

        <div class="store-header-bottom">
            <div class="store-category-wrapper">
                <div class="store-category-button">
                    <i class="bi bi-list"></i>
                    <span>TẤT CẢ DANH MỤC</span>
                </div>
                <div class="store-category-dropdown">
                    @foreach (var item in theLoaisLayout)
                    {
                        <a asp-controller="Home" asp-action="Index" asp-route-theLoaiId="@item.Id">
                            <i class="bi bi-journal-text me-2"></i> @item.TenTheLoai
                        </a>
                    }
                </div>
            </div>

            <nav class="store-main-nav">
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a href="/#categories">Thể loại</a>
                <a href="/#featured">Sách nổi bật</a>
                <a href="/#new">Sách mới</a>
                <a asp-controller="DatHang" asp-action="LichSu">Tra cứu đơn</a>
            </nav>
        </div>
    </header>

    <main class="@(isHomePage ? "" : "py-3")">
        @RenderBody()
    </main>

    <footer class="border-top text-muted py-3 @(isHomePage ? "mt-0" : "mt-4") bg-white">
        <div class="container text-center">
            &copy; 2026 - FrancisBooks - Nhà sách trực tuyến
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function () {
            let searchTimeout;
            const $searchInput = $('#searchInput');
            const $searchDropdown = $('#searchDropdown');

            $searchInput.on('input', function () {
                clearTimeout(searchTimeout);
                const query = $(this).val().trim();

                if (query.length < 2) {
                    $searchDropdown.hide();
                    return;
                }

                searchTimeout = setTimeout(function () {
                    $.ajax({
                        url: '/Home/SearchSuggestions',
                        type: 'GET',
                        data: { query: query },
                        success: function (data) {
                            $searchDropdown.empty();

                            if (data && data.length > 0) {
                                $.each(data, function (i, item) {
                                    const html = `
                                        <a href="/ChiTiet/Index/${item.id}" class="search-suggestion-item">
                                            <img src="${item.hinhAnh}" class="search-suggestion-img" alt="${item.tenSach}" onerror="this.src='/images/no-image.png'" />
                                            <div class="search-suggestion-info">
                                                <div class="search-suggestion-title">${item.tenSach}</div>
                                                <div class="search-suggestion-author">${item.tacGia}</div>
                                                <div class="search-suggestion-price">${item.gia}</div>
                                            </div>
                                        </a>
                                    `;
                                    $searchDropdown.append(html);
                                });
                                $searchDropdown.show();
                            } else {
                                $searchDropdown.html('<div class="p-3 text-muted text-center">Không tìm thấy sách phù hợp</div>');
                                $searchDropdown.show();
                            }
                        }
                    });
                }, 300); // 300ms debounce
            });

            // Hide dropdown when clicking outside
            $(document).on('click', function (e) {
                if (!$(e.target).closest('.search-dropdown-container').length) {
                    $searchDropdown.hide();
                }
            });

            // Show dropdown when input is focused and has text
            $searchInput.on('focus', function() {
                 if ($(this).val().trim().length >= 2 && $searchDropdown.children().length > 0) {
                     $searchDropdown.show();
                 }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>w