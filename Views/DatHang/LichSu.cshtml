@model IEnumerable<Book2.Models.DonHang>

@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Lịch sử đơn hàng</h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
            Mua tiếp
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đơn</th>
                                <th>Ngày đặt</th>
                                <th>Người nhận</th>
                                <th>SĐT</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th>Chi tiết</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>#@item.Id</td>
                                    <td>@item.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@item.TenNguoiNhan</td>
                                    <td>@item.SoDienThoai</td>
                                    <td class="fw-bold text-success">@item.TongTien.ToString("N0") VNĐ</td>
                                    <td>
                                        @if (item.TrangThai == "Chờ xác nhận")
                                        {
                                            <span class="badge bg-warning text-dark">@item.TrangThai</span>
                                        }
                                        else if (item.TrangThai == "Đang giao")
                                        {
                                            <span class="badge bg-primary">@item.TrangThai</span>
                                        }
                                        else if (item.TrangThai == "Hoàn thành")
                                        {
                                            <span class="badge bg-success">@item.TrangThai</span>
                                        }
                                        else if (item.TrangThai == "Đã hủy")
                                        {
                                            <span class="badge bg-danger">@item.TrangThai</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@item.TrangThai</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="ChiTiet" asp-route-id="@item.Id" class="btn btn-outline-dark btn-sm">
                                            Xem
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Bạn chưa có đơn hàng nào.
        </div>
    }
</div>