@using Microsoft.AspNetCore.Identity
@using Book2.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-lg-center">
    @if (SignInManager.IsSignedIn(User))
    {
        var appUser = await UserManager.GetUserAsync(User);
        <li class="nav-item">
            <a class="nav-link text-dark"
               asp-area="Identity"
               asp-page="/Account/Manage/Index">
                Xin chào @(appUser?.HoTen ?? User.Identity?.Name)
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link text-dark"
               asp-controller="Auth"
               asp-action="RedirectByRole">
                Vào trang quản lý
            </a>
        </li>

        <li class="nav-item">
            <form id="logoutForm"
                  class="d-inline"
                  asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button id="logout" type="submit" class="nav-link btn btn-link text-dark border-0">
                    Đăng xuất
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" id="register" asp-area="Identity" asp-page="/Account/Register">
                Đăng ký
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" id="login" asp-area="Identity" asp-page="/Account/Login">
                Đăng nhập
            </a>
        </li>
    }
</ul>